{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@starwars/api": ["packages/api/src"],
      "@starwars/domain": ["packages/domain/src"],
      "@starwars/store": ["packages/store/src"],
      "@starwars/ui": ["packages/ui/src"],
      "@starwars/utils": ["packages/utils/src"]
    },
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true
  }
}