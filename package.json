{
  "name": "starwars-explorer",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "format": "prettier --write \"**/*.{ts,tsx,css,json,md}\"",
    "format: check": "prettier --check \"**/*.{ts,tsx,css,json,md}\""
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.5.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "dependencies": {
    "@mantine/core": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "mobx": "^6.15.4",
    "mobx-react-lite": "^4.1.1",
    "react-router-dom": "^7.16.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "jest": "^30.4.2",
    "prettier": "^3.8.3"
  }
}
